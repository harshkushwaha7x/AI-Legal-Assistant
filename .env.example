# ── Database (REQUIRED) ──────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ai_legal_assistant?schema=public"

# ── Auth (REQUIRED) ──────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ── OAuth Providers (optional) ───────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# ── OpenAI (optional — fallback engines work without it)
OPENAI_API_KEY="sk-..."

# ── App (optional) ───────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LegalAI"


// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  USER
  LAWYER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum DocumentType {
  NDA
  LEASE
  CONTRACT
  EMPLOYMENT
  PARTNERSHIP
  CUSTOM
}

enum DocumentStatus {
  DRAFT
  REVIEW
  FINAL
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  ANALYZING
  COMPLETED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EscalationStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Models ──────────────────────────────────────────────────────────

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  image           String?
  passwordHash    String?
  role            UserRole         @default(USER)
  subscription    SubscriptionTier @default(FREE)
  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  documents       Document[]
  reviews         ContractReview[]
  chatSessions    ChatSession[]
  escalations     LawyerEscalation[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([email])
  @@index([organizationId])
}

model Organization {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  domain      String?
  logo        String?
  members     User[]
  templates   Template[]
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
}

model Document {
  id              String         @id @default(cuid())
  title           String
  type            DocumentType
  status          DocumentStatus @default(DRAFT)
  content         String         @db.Text
  metadata        Json?
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  templateId      String?
  template        Template?      @relation(fields: [templateId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([type])
}

model Template {
  id              String       @id @default(cuid())
  name            String
  description     String?
  type            DocumentType
  content         String       @db.Text
  variables       Json         @default("[]")
  isPublic        Boolean      @default(false)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  documents       Document[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([type])
  @@index([organizationId])
}

model ContractReview {
  id            String       @id @default(cuid())
  fileName      String
  fileUrl       String
  fileSize      Int
  status        ReviewStatus @default(PENDING)
  riskScore     Float?
  riskLevel     RiskLevel?
  summary       String?      @db.Text
  findings      Json?
  clauses       Json?
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String        @default("New Conversation")
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  role        String      // "user" | "assistant" | "system"
  content     String      @db.Text
  metadata    Json?
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}

model LawyerEscalation {
  id          String           @id @default(cuid())
  subject     String
  description String           @db.Text
  status      EscalationStatus @default(PENDING)
  priority    Int              @default(0)
  assignedTo  String?
  notes       String?          @db.Text
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

model LegalKnowledge {
  id          String   @id @default(cuid())
  title       String
  category    String
  content     String   @db.Text
  embedding   Json?
  source      String?
  jurisdiction String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}
